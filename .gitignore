# ── Raw data (too large for repo) ─────────────────────────────────────────────
data/raw/
data/external/
data/tmp/
data/cache/

# ── Processed data (regenerable — keep .gitkeep only) ─────────────────────────
data/processed/*.csv
data/processed/*.json
data/processed/*.parquet

# ── Large data formats ───────────────────────────────────────────────────────
*.zip
*.parquet
*.feather
*.pkl
*.pickle

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.*

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs & temp ───────────────────────────────────────────────────────────────
*.log
*.tmp
data/raw/stream_status.txt

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Pytest ────────────────────────────────────────────────────────────────────
.pytest_cache/

# ── Keep these (explicit) ─────────────────────────────────────────────────────
